# ─── Auth0 (Backend) ─────────────────────────────────────────────────────────
AUTH0_DOMAIN=vouch-dev.us.auth0.com
AUTH0_CLIENT_ID=YOUR_SPA_CLIENT_ID
AUTH0_CLIENT_SECRET=YOUR_SPA_CLIENT_SECRET
AUTH0_MGMT_CLIENT_ID=YOUR_MGMT_CLIENT_ID
AUTH0_MGMT_CLIENT_SECRET=YOUR_MGMT_CLIENT_SECRET
AUTH0_AUDIENCE=https://api.vouch.dev

# ─── App ──────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=3001
FRONTEND_URL=http://localhost:5173
API_BASE_URL=http://localhost:3001
CORS_ALLOWED_ORIGINS=http://localhost:5173
NODE_ENV=development
DEMO_MODE=false
SERVE_DASHBOARD=false
TRUST_PROXY=1
JSON_BODY_LIMIT=1mb
VOUCH_DATA_DIR=.vouch-data

# ─── Frontend (Dashboard) ─────────────────────────────────────────────────────
VITE_AUTH0_DOMAIN=vouch-dev.us.auth0.com
VITE_AUTH0_CLIENT_ID=YOUR_SPA_CLIENT_ID
VITE_AUTH0_AUDIENCE=https://api.vouch.dev
VITE_AUTH0_GITHUB_CONNECTION=github
VITE_AUTH0_LINEAR_CONNECTION=linear
VITE_API_URL=http://localhost:3001

# ─── SDK/CLI ──────────────────────────────────────────────────────────────────
VOUCH_API_URL=http://localhost:3001
VOUCH_DELEGATION_ID=del_demo
VOUCH_M2M_CLIENT_ID=YOUR_M2M_CLIENT_ID
VOUCH_M2M_CLIENT_SECRET=YOUR_M2M_CLIENT_SECRET
VOUCH_AUTH0_AUDIENCE=https://api.vouch.dev
GROQ_API_KEY=YOUR_GROQ_API_KEY
